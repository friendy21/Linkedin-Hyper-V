# LinkedIn Hyper-V Environment Configuration
# Copy this file to .env and fill in your own values
# DO NOT commit .env to version control

# =============================================================================
# SECURITY CRITICAL: Rotate these secrets in production
# =============================================================================

# Redis Configuration
REDIS_PASSWORD=your_secure_redis_password_here
REDIS_PORT=6379
REDIS_HOST=redis
REDIS_URL=redis://:your_secure_redis_password_here@redis:6379

# API Security
API_KEY=your_secure_api_key_here
API_SECRET=your_secure_api_secret_here
API_ROUTE_AUTH_TOKEN=

# Authentication
JWT_SECRET=your_secure_jwt_secret_min_32_characters_long
SESSION_ENCRYPTION_KEY=your_secure_session_encryption_key_64_chars
DASHBOARD_PASSWORD=your_secure_dashboard_password
SESSION_MAX_AGE=86400

# Proxy Configuration
PROXY_AUTH_TOKENS={"dev-admin-token":"admin"}
PROXY_AUTH_COOKIE_NAME=proxy_session

# Database
DB_PASSWORD=your_secure_db_password
DATABASE_URL=postgresql://linkedinuser:your_secure_db_password@postgres:5432/linkedin_db

# Worker API
API_URL=http://worker:3001

# Frontend URLs (update with your actual domain)
NEXT_PUBLIC_API_URL=https://your-domain.com
NEXT_PUBLIC_WS_URL=wss://your-domain.com/ws

# Security
TRUSTED_ORIGINS=https://your-domain.com

# Intervals
NOTIFICATION_SCRAPE_INTERVAL_MINUTES=5
SYNC_INTERVAL_MINUTES=10
